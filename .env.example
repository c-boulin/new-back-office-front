# API — dating-backoffice-api
VITE_API_BASE_URL=https://876avtwsc1.execute-api.eu-west-1.amazonaws.com/dev/api

# Product identity injected in auth bodies and metier queries.
VITE_DEFAULT_PRODUCT_ID=69

# Authentication methods (at least one must be true)
VITE_AUTH_PASSWORD_ENABLED=true
VITE_AUTH_SSO_ENABLED=true

# When true, /v1/auth/sso/* bypasses the mock adapter and hits VITE_API_BASE_URL.
# Set to true whenever you want the "Continue with Microsoft" button to reach the
# real backend even while the rest of the app runs on seeds.
VITE_AUTH_SSO_REAL=false

# Mocks
VITE_MOCK_API=false
VITE_MOCK_PERSIST=false

# Feature flags
VITE_ENABLE_MSW=false
